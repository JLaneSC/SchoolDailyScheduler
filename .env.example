# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Client-side (safe to expose to the browser; protected by Supabase Row-Level
# Security policies, not by secrecy).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only. Set this via `supabase secrets set ANTHROPIC_API_KEY=...`
# for use inside a Supabase Edge Function. Do NOT prefix it with VITE_ and do
# NOT put it in any file that ships to the browser.
# ANTHROPIC_API_KEY=
